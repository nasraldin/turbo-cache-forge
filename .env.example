# --- docker compose (infra/docker/docker-compose.yml) Postgres creds ---
# The compose Postgres service is NOT published to the host (no 5432:5432
# mapping); cache-api and migrate reach it over the compose network only.
# Override these before self-hosting anywhere beyond local dev.
POSTGRES_USER=tcf
POSTGRES_PASSWORD=tcf
POSTGRES_DB=tcf

ADDR=:8080
# For running cache-api directly on the host against a locally-installed
# Postgres (not the compose stack, whose Postgres port isn't published).
DATABASE_URL=postgres://tcf:tcf@localhost:5432/tcf?sslmode=disable
STORAGE_BACKEND=fs           # fs | s3
STORAGE_PATH=/var/lib/turbo-cache-forge
# --- S3/R2 (only when STORAGE_BACKEND=s3) ---
STORAGE_S3_BUCKET=
STORAGE_S3_ENDPOINT=         # https://<acct>.r2.cloudflarestorage.com  | http://localhost:9000 (MinIO)
STORAGE_S3_REGION=auto
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
MAX_UPLOAD_BYTES=1073741824
