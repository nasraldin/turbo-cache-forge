# The ONLY backend coupling — points at the Phase-3 Go API.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Clerk (browser session -> JWT sent to /api/v1).
# These are placeholders. Real keys are required at RUNTIME (Clerk validates
# the publishable key format even for `next build`, so the dummy value below
# is also what CI/build environments should set if no real key is available —
# see apps/dashboard's own README note / task-3 report for details).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
