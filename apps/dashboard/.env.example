# The ONLY backend coupling — points at the Phase-3 Go API.
NEXT_PUBLIC_API_URL=http://localhost:8080

# The dashboard auto-detects the auth mode at runtime via
# GET ${NEXT_PUBLIC_API_URL}/api/v1/auth/config — no rebuild needed to switch
# between built-in and OIDC. Clerk vars below are only needed for AUTH_MODE=oidc.

# Clerk (browser session -> JWT sent to /api/v1). Real keys required at RUNTIME.
# NOTE: Clerk validates the publishable key FORMAT even during `next build`
# (it base64-decodes to a frontend host), so `pk_test_xxx` will FAIL the build.
# The value below is a valid-FORMAT throwaway (base64 of "example.clerk.accounts.dev$")
# that lets CI / Docker `next build` prerender; swap in your real keys to run.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_ZXhhbXBsZS5jbGVyay5hY2NvdW50cy5kZXYk
# CLERK_SECRET_KEY is the oidc/builtin switch for the dashboard middleware: when it
# is SET, middleware.ts runs Clerk auth. For AUTH_MODE=builtin it MUST be UNSET
# (otherwise every route redirect-loops to /sign-in). Set a real value only for
# AUTH_MODE=oidc.
# CLERK_SECRET_KEY=sk_live_your_real_secret_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
